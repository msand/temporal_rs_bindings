{
  "name": "temporal_rs",
  "version": "0.1.1",
  "main": "index.js",
  "module": "lib/temporal.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/temporal.mjs",
      "require": "./index.js",
      "types": "./index.d.ts"
    },
    "./native": {
      "import": "./index.js",
      "require": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/msand/temporal_rs_bindings"
  },
  "napi": {
    "name": "temporal_rs",
    "triples": {
      "defaults": true,
      "additional": ["aarch64-apple-darwin"]
    }
  },
  "scripts": {
    "build": "napi build --platform --release --cargo-cwd crates/temporal-napi",
    "build:debug": "napi build --platform --cargo-cwd crates/temporal-napi",
    "build:wasm": "wasm-pack build crates/temporal-wasm --target bundler --out-dir ../../wasm-pkg",
    "test": "vitest run",
    "test262": "node --harmony-intl-duration-format test262-runner.mjs",
    "test262:verbose": "node --harmony-intl-duration-format test262-runner.mjs -v",
    "test262:failing": "node --harmony-intl-duration-format test262-runner.mjs --failing"
  },
  "files": ["index.js", "index.d.ts", "lib/"],
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "vitest": "^1"
  },
  "optionalDependencies": {
    "temporal_rs-darwin-arm64": "0.1.1",
    "temporal_rs-darwin-x64": "0.1.1",
    "temporal_rs-linux-x64-gnu": "0.1.1",
    "temporal_rs-linux-x64-musl": "0.1.1",
    "temporal_rs-linux-arm64-gnu": "0.1.1",
    "temporal_rs-win32-x64-msvc": "0.1.1",
    "temporal_rs-win32-arm64-msvc": "0.1.1"
  }
}
