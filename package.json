{
  "name": "temporal_rs",
  "version": "0.1.5",
  "license": "MIT",
  "type": "commonjs",
  "main": "lib/temporal.js",
  "module": "lib/temporal.mjs",
  "types": "lib/temporal.d.ts",
  "exports": {
    ".": {
      "types": "./lib/temporal.d.ts",
      "import": "./lib/temporal.mjs",
      "require": "./lib/temporal.js"
    },
    "./native": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    },
    "./wasm": {
      "types": "./wasm-pkg/temporal_wasm.d.ts",
      "import": "./wasm-pkg/temporal_wasm.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/msand/temporal_rs_bindings"
  },
  "napi": {
    "name": "temporal_rs",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release --cargo-cwd crates/temporal-napi && tsup",
    "build:debug": "napi build --platform --cargo-cwd crates/temporal-napi && tsup",
    "build:napi": "napi build --platform --release --cargo-cwd crates/temporal-napi",
    "build:ts": "tsup",
    "build:wasm": "wasm-pack build crates/temporal-wasm --target bundler --out-dir ../../wasm-pkg && rm -f wasm-pkg/.gitignore",
    "test": "vitest run",
    "test262": "node test262-runner.mjs",
    "test262:verbose": "node test262-runner.mjs -v",
    "test262:failing": "node test262-runner.mjs --failing",
    "lint": "eslint lib/temporal.ts tsup.config.ts eslint.config.mjs",
    "lint:fix": "eslint lib/temporal.ts tsup.config.ts eslint.config.mjs --fix",
    "format": "prettier --write 'lib/temporal.ts' 'tsup.config.ts' 'eslint.config.mjs' '*.json' '!package-lock.json' '__test__/*.ts'",
    "format:check": "prettier --check 'lib/temporal.ts' 'tsup.config.ts' 'eslint.config.mjs' '*.json' '!package-lock.json' '__test__/*.ts'",
    "version": "./scripts/bump-version.sh",
    "prepublishOnly": "tsup"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lib/temporal.js",
    "lib/temporal.js.map",
    "lib/temporal.mjs",
    "lib/temporal.mjs.map",
    "lib/temporal.d.ts",
    "lib/temporal.d.mts",
    "wasm-pkg/"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@napi-rs/cli": "^2.18.4",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "temporal_rs-darwin-arm64": "0.1.5",
    "temporal_rs-darwin-x64": "0.1.5",
    "temporal_rs-linux-arm64-gnu": "0.1.5",
    "temporal_rs-linux-x64-gnu": "0.1.5",
    "temporal_rs-linux-x64-musl": "0.1.5",
    "temporal_rs-win32-arm64-msvc": "0.1.5",
    "temporal_rs-win32-x64-msvc": "0.1.5"
  }
}
