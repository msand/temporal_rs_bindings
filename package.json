{
  "name": "temporal_rs",
  "version": "0.1.0",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "temporal_rs",
    "triples": {
      "defaults": true,
      "additional": ["aarch64-apple-darwin"]
    }
  },
  "scripts": {
    "build": "napi build --platform --release --cargo-cwd crates/temporal-napi",
    "build:debug": "napi build --platform --cargo-cwd crates/temporal-napi",
    "build:wasm": "wasm-pack build crates/temporal-wasm --target bundler --out-dir ../../wasm-pkg",
    "test": "vitest run"
  },
  "files": ["index.js", "index.d.ts"],
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "vitest": "^1"
  },
  "optionalDependencies": {
    "temporal_rs-darwin-arm64": "0.1.0",
    "temporal_rs-darwin-x64": "0.1.0",
    "temporal_rs-linux-x64-gnu": "0.1.0",
    "temporal_rs-linux-x64-musl": "0.1.0",
    "temporal_rs-linux-arm64-gnu": "0.1.0",
    "temporal_rs-win32-x64-msvc": "0.1.0",
    "temporal_rs-win32-arm64-msvc": "0.1.0"
  }
}
